import numpy as np
import cv2
import matplotlib.pyplot as plt

def canny(lane_image):
    if lane_image is None:
        print("Error: Image not loaded")
        return None
    
    gray = cv2.cvtColor(lane_image, cv2.COLOR_BGR2GRAY)
    blur = cv2.GaussianBlur(gray, (5, 5), 1)
    canny_image = cv2.Canny(blur, 50, 150)
    return canny_image
# REMOVE THIS AND MODIFY FOR YOUR IMAGE
def region_of_interest(lane_image):
    height = lane_image.shape[0]
    width = lane_image.shape[1]

    triangle = np.array([[(200, height), (1100, height), (550, 250)]])
    mask = np.zeros_like(lane_image)
    cv2.fillPoly(mask, triangle, 255)
    masked_image = cv2.bitwise_and(lane_image, mask)
    return masked_image

def display_line(image, lines):
    line_image = np.zeros_like(image)   # fixed
    if lines is not None:
        for line in lines:
            print(line)
    return line_image   # fixed

# Read image
image = cv2.imread('test_image.jpg')
if image is None:
    print("Error: Could not read image")
    exit()
 
# Create a copy
lane_image = np.copy(image)

# Apply canny
canny_output = canny(lane_image)
# 👇
# Apply ROI
roi_output = region_of_interest(canny_output)
# 👇
# Hough Transform (fixed argument)
lines = cv2.HoughLinesP(roi_output,2,np.pi/180,100,np.array([]),40,5)

# Display lines
line_image = display_line(roi_output, lines)

cv2.imshow("Cropped_Output", roi_output)
cv2.waitKey(0)
cv2.destroyAllWindows()
